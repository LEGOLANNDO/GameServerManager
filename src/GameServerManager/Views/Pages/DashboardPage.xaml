<Page
    x:Class="GameServerManager.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GameServerManager.ViewModels"
    xmlns:helpers="clr-namespace:GameServerManager.Helpers"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
    Title="ダッシュボード">

    <Page.Resources>
        <!-- ステータスカラーブラシ -->
        <SolidColorBrush x:Key="RunningBrush" Color="#2ECC71" />
        <SolidColorBrush x:Key="StoppedBrush" Color="#95A5A6" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#E74C3C" />

        <!-- コンバーター -->
        <helpers:InverseCountToVisibilityConverter x:Key="InverseCountToVisibilityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- 稼働中バッジの点滅アニメーション -->
        <Storyboard x:Key="RunningPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="1.0" To="0.5"
                Duration="0:0:0.8"
                AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Text="ダッシュボード"
                    FontSize="28"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="登録されたゲームサーバーの一覧とステータス"
                    FontSize="14"
                    Opacity="0.6"
                    Margin="0,4,0,0" />
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                Content="更新"
                Icon="{ui:SymbolIcon ArrowSync24}"
                Appearance="Primary"
                Command="{Binding RefreshCommand}"
                VerticalAlignment="Center" />
        </Grid>

        <!-- サーバー一覧（カードリスト） -->
        <Grid Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Servers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl
                            Width="380"
                            Margin="0,0,16,16"
                            Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- サーバー名 + ステータスバッジ -->
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />

                                    <!-- ステータスバッジ -->
                                    <Border
                                        x:Name="StatusBadge"
                                        Grid.Column="1"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource StoppedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="Background" Value="{StaticResource RunningBrush}" />
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="PulseStoryboard" Storyboard="{StaticResource RunningPulseAnimation}" />
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                        <Setter Property="Background" Value="{StaticResource ErrorBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            FontSize="12"
                                            Foreground="White"
                                            FontWeight="Medium" />
                                    </Border>
                                </Grid>

                                <!-- タイプ -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                                    <ui:SymbolIcon Symbol="Apps24" Margin="0,0,8,0" FontSize="14" />
                                    <TextBlock Text="タイプ: " FontSize="13" Opacity="0.7" />
                                    <TextBlock Text="{Binding Type}" FontSize="13" FontWeight="Medium" />
                                </StackPanel>

                                <!-- パス -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                                    <ui:SymbolIcon Symbol="Folder24" Margin="0,0,8,0" FontSize="14" />
                                    <TextBlock
                                        Text="{Binding ExecutablePath}"
                                        FontSize="12"
                                        Opacity="0.5"
                                        MaxWidth="270"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <!-- 稼働時間 -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ui:SymbolIcon Symbol="Clock24" Margin="0,0,8,0" FontSize="14" />
                                    <TextBlock Text="稼働時間: " FontSize="13" Opacity="0.7" />
                                    <TextBlock Text="{Binding UptimeText}" FontSize="13" FontWeight="Medium" />
                                </StackPanel>

                                <!-- リソース情報 -->
                                <Grid Grid.Row="4" Margin="0,8,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CPU" FontSize="11" Opacity="0.5" />
                                        <TextBlock FontSize="16" FontWeight="Medium">
                                            <Run Text="{Binding CpuUsage, StringFormat={}{0:F1}}" />
                                            <Run Text="%" />
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="メモリ" FontSize="11" Opacity="0.5" />
                                        <TextBlock FontSize="16" FontWeight="Medium">
                                            <Run Text="{Binding MemoryUsageMb, StringFormat={}{0:F0}}" />
                                            <Run Text="MB" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- アクションボタン -->
                                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <!-- スケジュールボタン -->
                                    <ui:Button
                                        Content="スケジュール"
                                        Icon="{ui:SymbolIcon Timer24}"
                                        Appearance="Secondary"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.SetScheduleCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}" />
                                    <!-- 起動ボタン (停止中のみ表示) -->
                                    <ui:Button
                                        Content="起動"
                                        Icon="{ui:SymbolIcon Play24}"
                                        Appearance="Success"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.StartServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding IsStopped, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- 再起動ボタン (稼働中のみ表示) -->
                                    <ui:Button
                                        Content="再起動"
                                        Icon="{ui:SymbolIcon ArrowSync24}"
                                        Appearance="Caution"
                                        Margin="0,0,8,0"
                                        Command="{Binding DataContext.RestartServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <!-- 停止ボタン (稼働中のみ表示) -->
                                    <ui:Button
                                        Content="停止"
                                        Icon="{ui:SymbolIcon Stop24}"
                                        Appearance="Danger"
                                        Command="{Binding DataContext.StopServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>

                                <!-- スケジュール表示 -->
                                <TextBlock
                                    Grid.Row="6"
                                    Text="{Binding ScheduleText}"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    FontSize="12"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Right">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ScheduleText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- サーバー未登録時の表示 -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding Servers.Count, Converter={StaticResource InverseCountToVisibilityConverter}, FallbackValue=Visible}">
            <ui:SymbolIcon
                Symbol="Server24"
                FontSize="64"
                Opacity="0.3"
                HorizontalAlignment="Center" />
            <TextBlock
                Text="サーバーが登録されていません"
                FontSize="18"
                Opacity="0.5"
                HorizontalAlignment="Center"
                Margin="0,16,0,8" />
            <TextBlock
                Text="設定ページからサーバーを追加してください"
                FontSize="14"
                Opacity="0.3"
                HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>

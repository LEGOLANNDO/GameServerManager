<Page
    x:Class="GameServerManager.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:GameServerManager.ViewModels"
    xmlns:helpers="clr-namespace:GameServerManager.Helpers"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
    Title="設定">

    <Page.Resources>
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
    </Page.Resources>

    <Grid>
        <StackPanel Margin="24,16,24,24" MaxWidth="800">

            <!-- ページタイトル -->
            <TextBlock
                Text="設定"
                FontSize="28"
                FontWeight="SemiBold"
                Margin="0,0,0,24" />

            <!-- ===== アプリケーション設定セクション ===== -->
            <TextBlock
                Text="アプリケーション"
                FontSize="16"
                FontWeight="SemiBold"
                Margin="0,0,0,12" />

            <ui:CardExpander Header="テーマ" Icon="{ui:SymbolIcon PaintBrush24}" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="16">
                    <TextBlock Text="アプリケーションのテーマを選択" FontSize="13" Opacity="0.7" Margin="0,0,0,8" />
                    <ComboBox
                        ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding CurrentTheme, Mode=TwoWay}"
                        Width="200"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Header="監視設定" Icon="{ui:SymbolIcon Timer24}" Margin="0,0,0,8">
                <StackPanel Margin="16">
                    <TextBlock Text="プロセス監視のポーリング間隔（秒）" FontSize="13" Opacity="0.7" Margin="0,0,0,8" />
                    <ui:NumberBox
                        Value="{Binding PollingInterval, Mode=TwoWay}"
                        Minimum="1"
                        Maximum="30"
                        SpinButtonPlacementMode="Inline"
                        Width="200"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </ui:CardExpander>

            <!-- ===== Discord連携セクション ===== -->
            <TextBlock
                Text="Discord連携"
                FontSize="16"
                FontWeight="SemiBold"
                Margin="0,24,0,12" />

            <ui:CardExpander Header="グローバル Webhook URL" Icon="{ui:SymbolIcon Link24}" IsExpanded="True" Margin="0,0,0,8">
                <StackPanel Margin="16">
                    <TextBlock Text="すべてのサーバーに適用されるデフォルトのWebhook URL" FontSize="13" Opacity="0.7" Margin="0,0,0,4" />
                    <TextBlock Text="※ DPAPI で暗号化して保存されます" FontSize="11" Opacity="0.4" Margin="0,0,0,8" />
                    <ui:TextBox
                        Text="{Binding GlobalWebhookUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="https://discord.com/api/webhooks/..."
                        Icon="{ui:SymbolIcon Shield24}" />

                    <!-- テスト送信ボタン + 結果表示 -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button
                            Content="テスト通知を送信"
                            Icon="{ui:SymbolIcon Send24}"
                            Appearance="Secondary"
                            Command="{Binding TestWebhookCommand}"
                            IsEnabled="{Binding IsTestingWebhook, Converter={StaticResource InverseBoolConverter}}" />
                        <TextBlock
                            Text="{Binding WebhookTestResult}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <!-- Discord Embed ライブプレビュー (§4.2) -->
            <ui:CardExpander Header="通知プレビュー" Icon="{ui:SymbolIcon Eye24}" Margin="0,0,0,8">
                <StackPanel Margin="16">
                    <TextBlock Text="実際にDiscordに送信されるEmbedの見本" FontSize="13" Opacity="0.7" Margin="0,0,0,12" />

                    <!-- Discord風プレビュー: 起動通知 -->
                    <Border Background="#2F3136" CornerRadius="4" Padding="0" Margin="0,0,0,8">
                        <Grid>
                            <!-- 左のカラーバー -->
                            <Border Background="#2ECC71" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4" />
                            <StackPanel Margin="16,12,12,12">
                                <TextBlock Text="🟢【起動】サンプルサーバー" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="起動時刻" FontSize="11" Foreground="#72767D" />
                                        <TextBlock Text="2025/01/01 12:00:00" FontSize="12" Foreground="#DCDDDE" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Discord風プレビュー: 停止通知 -->
                    <Border Background="#2F3136" CornerRadius="4" Padding="0" Margin="0,0,0,8">
                        <Grid>
                            <Border Background="#E67E22" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4" />
                            <StackPanel Margin="16,12,12,12">
                                <TextBlock Text="🛑【停止 - 計画的】サンプルサーバー" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="実施区分" FontSize="11" Foreground="#72767D" />
                                        <TextBlock Text="計画的" FontSize="12" Foreground="#DCDDDE" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="実行時刻" FontSize="11" Foreground="#72767D" />
                                        <TextBlock Text="2025/01/01 18:00:00" FontSize="12" Foreground="#DCDDDE" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Margin="0,6,0,0">
                                    <TextBlock Text="停止理由" FontSize="11" Foreground="#72767D" />
                                    <TextBlock Text="定期メンテナンスのため" FontSize="12" Foreground="#DCDDDE" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Discord風プレビュー: クラッシュ通知 -->
                    <Border Background="#2F3136" CornerRadius="4" Padding="0">
                        <Grid>
                            <Border Background="#E74C3C" Width="4" HorizontalAlignment="Left" CornerRadius="4,0,0,4" />
                            <StackPanel Margin="16,12,12,12">
                                <TextBlock Text="🚨【クラッシュ・異常停止】サンプルサーバー" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="停止検出時刻" FontSize="11" Foreground="#72767D" />
                                        <TextBlock Text="2025/01/01 03:45:12" FontSize="12" Foreground="#DCDDDE" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="終了コード" FontSize="11" Foreground="#72767D" />
                                        <TextBlock Text="-1" FontSize="12" Foreground="#DCDDDE" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ui:CardExpander>

            <!-- 保存ボタン -->
            <ui:Button
                Content="設定を保存"
                Icon="{ui:SymbolIcon Save24}"
                Appearance="Primary"
                Command="{Binding SaveSettingsCommand}"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Padding="24,8" />

            <!-- ステータスメッセージ -->
            <TextBlock
                Text="{Binding StatusMessage}"
                FontSize="13"
                HorizontalAlignment="Right"
                Margin="0,8,0,0"
                Opacity="0.8" />

            <!-- ===== サーバー管理セクション ===== -->
            <Separator Margin="0,32,0,16" />

            <TextBlock
                Text="サーバー管理"
                FontSize="16"
                FontWeight="SemiBold"
                Margin="0,0,0,12" />

            <!-- サーバー追加フォーム -->
            <ui:CardExpander Header="新しいサーバーを追加" Icon="{ui:SymbolIcon Add24}" Margin="0,0,0,16">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- サーバー名 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="サーバー名" VerticalAlignment="Center" FontSize="13" />
                    <ui:TextBox Grid.Row="0" Grid.Column="1"
                        Text="{Binding NewServerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="例: Palworld Dedicated Server"
                        Margin="0,0,0,8" />

                    <!-- タイプ -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="タイプ" VerticalAlignment="Center" FontSize="13" />
                    <ComboBox Grid.Row="1" Grid.Column="1"
                        ItemsSource="{Binding AvailableServerTypes}"
                        SelectedItem="{Binding NewServerType, Mode=TwoWay}"
                        Width="150"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8" />

                    <!-- 実行ファイルパス -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="実行パス" VerticalAlignment="Center" FontSize="13" />
                    <ui:TextBox Grid.Row="2" Grid.Column="1"
                        Text="{Binding NewServerPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="例: C:\SteamCMD\palServer\PalServer.exe"
                        Margin="0,0,0,8" />

                    <!-- 引数 -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="引数" VerticalAlignment="Center" FontSize="13" />
                    <ui:TextBox Grid.Row="3" Grid.Column="1"
                        Text="{Binding NewServerArguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="例: -port=8211 -players=32"
                        Margin="0,0,0,8" />

                    <!-- 作業ディレクトリ -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="作業ディレクトリ" VerticalAlignment="Center" FontSize="13" />
                    <ui:TextBox Grid.Row="4" Grid.Column="1"
                        Text="{Binding NewServerWorkingDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="例: C:\SteamCMD\palServer"
                        Margin="0,0,0,8" />

                    <!-- Webhook URL -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Webhook URL" VerticalAlignment="Center" FontSize="13" />
                    <ui:TextBox Grid.Row="5" Grid.Column="1"
                        Text="{Binding NewServerWebhook, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="空欄の場合グローバル設定を使用"
                        Margin="0,0,0,12" />

                    <!-- 追加ボタン -->
                    <ui:Button Grid.Row="6" Grid.Column="1"
                        Content="サーバーを追加"
                        Icon="{ui:SymbolIcon Add24}"
                        Appearance="Primary"
                        Command="{Binding AddServerCommand}"
                        HorizontalAlignment="Right" />
                </Grid>
            </ui:CardExpander>

            <!-- 登録済みサーバー一覧 -->
            <ItemsControl ItemsSource="{Binding Servers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl Margin="0,0,0,8" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="Medium" />
                                        </Border>
                                        <TextBlock Text="{Binding ExecutablePath}" FontSize="12" Opacity="0.5" VerticalAlignment="Center"
                                            MaxWidth="400" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                    Icon="{ui:SymbolIcon Delete24}"
                                    Appearance="Danger"
                                    Command="{Binding DataContext.RemoveServerCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="このサーバーを削除"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Grid>
</Page>

<ui:ContentDialog
    x:Class="GameServerManager.Views.Dialogs.ShutdownReasonDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="操作の確認"
    PrimaryButtonText="実行"
    CloseButtonText="キャンセル"
    DialogMaxWidth="480"
    IsPrimaryButtonEnabled="True"
    Style="{StaticResource {x:Type ui:ContentDialog}}">

    <StackPanel Margin="0,8,0,0">

        <!-- 操作内容の説明 -->
        <TextBlock
            x:Name="OperationDescription"
            FontSize="15"
            FontWeight="SemiBold"
            TextWrapping="Wrap"
            Margin="0,0,0,16" />

        <!-- 分類 (計画的 / 非計画的) -->
        <TextBlock Text="分類" FontSize="13" FontWeight="Medium" Margin="0,0,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton
                x:Name="PlannedRadio"
                Content="計画的 (Planned)"
                IsChecked="True"
                Margin="0,0,24,0"
                FontSize="13" />
            <RadioButton
                x:Name="UnplannedRadio"
                Content="非計画的 (Unplanned)"
                FontSize="13" />
        </StackPanel>

        <!-- 理由 -->
        <TextBlock Text="理由" FontSize="13" FontWeight="Medium" Margin="0,0,0,8" />
        <ui:TextBox
            x:Name="ReasonTextBox"
            PlaceholderText="例: Mod更新のため / メモリ解放 / 緊急メンテナンス"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            MinHeight="80"
            MaxHeight="160"
            VerticalContentAlignment="Top" />

        <TextBlock
            Text="※ 入力された理由はDiscord通知に含まれます"
            FontSize="11"
            Opacity="0.4"
            Margin="0,8,0,0" />
    </StackPanel>
</ui:ContentDialog>

<ui:FluentWindow
    x:Class="GameServerManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:pages="clr-namespace:GameServerManager.Views.Pages"
    mc:Ignorable="d"
    Title="Game Server Manager"
    Height="700"
    Width="1100"
    MinHeight="500"
    MinWidth="800"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- カスタムタイトルバー -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="Game Server Manager"
            Icon="pack://application:,,,/Assets/app-icon.ico" />

        <!-- ナビゲーションビュー -->
        <ui:NavigationView
            x:Name="NavigationView"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="True"
            OpenPaneLength="200">

            <ui:NavigationView.Header>
                <ui:BreadcrumbBar
                    Margin="42,32,0,0"
                    FontSize="28"
                    FontWeight="DemiBold" />
            </ui:NavigationView.Header>

            <!-- ナビゲーションメニュー項目 -->
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="ダッシュボード"
                    Icon="{ui:SymbolIcon Home24}"
                    TargetPageType="{x:Type pages:DashboardPage}" />
            </ui:NavigationView.MenuItems>

            <!-- フッターメニュー -->
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="設定"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>

        <!-- タスクトレイアイコン -->
        <tray:NotifyIcon
            x:Name="TrayIcon"
            Grid.Row="0"
            FocusOnLeftClick="True"
            MenuOnRightClick="True"
            TooltipText="Game Server Manager"
            Icon="pack://application:,,,/Assets/app-icon.ico"
            LeftDoubleClick="TrayIcon_OnLeftDoubleClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem Header="表示" Click="ShowWindow_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Window24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="終了" Click="ExitApp_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Power24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- ダイアログホスト用 ContentPresenter -->
        <ContentPresenter x:Name="RootContentDialog" Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="1000" />
    </Grid>
</ui:FluentWindow>
